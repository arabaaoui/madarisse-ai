# ── Supabase (même projet que ecole-muret) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://supabase.madarisse.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here  # backend only, jamais exposé au front

# ── Agent service (FastAPI/ADK) ───────────────────────────────────────────────
AGENT_SERVICE_URL=http://localhost:8001
AGENT_SERVICE_SECRET=your_internal_secret_here  # secret partagé Next.js ↔ ADK

# ── LiteLLM / modèles ─────────────────────────────────────────────────────────
LITELLM_API_BASE=http://localhost:4000
# Clés LLM (ne jamais committer)
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
